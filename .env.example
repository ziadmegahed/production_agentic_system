# ==================================================
# Application Settings
# ==================================================
APP_ENV=development              # Application environment (development | staging | test | production)
PROJECT_NAME="Web Assistant"     # Human-readable project name
VERSION=1.0.0                    # Application version
PROJECT_ROOT="root/project"      # Project Root

# ==================================================
# Logging Settings
# ==================================================
DEBUG=true                      # Enable debug mode (disable in production)
LOG_LEVEL="DEBUG"               # Log level (DEBUG | INFO | WARNING | ERROR)
LOG_RENDERER="console"          # Log renderer (console | json)
LOG_DIR="storage/logs"          # Directory for application logs
LOG_MAX_BYTES=10485760          # Maximum log file size in bytes (10 MB)
LOG_BACKUP_COUNT=10             # Number of backup log files to keep